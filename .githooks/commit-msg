#!/bin/sh
# Enforce Conventional Commits.
# Canonical source for the project commit policy: .specify/memory/constitution.md

msg_file="$1"

first_line=$(grep -vE '^[[:space:]]*#' "$msg_file" | grep -vE '^[[:space:]]*$' | head -n 1)

case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*)
    exit 0
    ;;
esac

pattern='^(feat|fix|docs|refactor|perf|test|build|ci|chore|style|revert)(\([a-zA-Z0-9._/-]+\))?(!)?: .+'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'

  ✖ Commit message rejected: must follow Conventional Commits.

  Required header:
    <type>[optional scope]: <description>

  Allowed types:
    feat, fix, docs, refactor, perf, test, build, ci, chore, style, revert

  Breaking change: add "!" after type/scope, or a "BREAKING CHANGE:" footer.

  Examples:
    feat: allow provided config object to extend other configs
    fix(worker): release stale socket on shutdown
    feat!: drop support for legacy config format

EOF

exit 1
