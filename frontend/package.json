{
  "name": "ppi-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "i18n:extract": "node ./scripts/i18next-cli.mjs extract",
    "i18n:check": "node ./scripts/i18next-cli.mjs extract --check",
    "openapi:export": "uv run --project .. python scripts/export_openapi.py --output ../openapi/openapi.json",
    "openapi:types": "openapi-typescript ../openapi/openapi.json -o src/api/generated/schema.d.ts",
    "openapi:check": "bash scripts/check_openapi.sh",
    "check:frontend-boundaries": "uv run --project .. python ../scripts/check_frontend_boundaries.py",
    "check:dead": "knip --no-exit-code",
    "check:all": "npm run typecheck && npm run check:dead && npm run check:frontend-boundaries && npm run i18n:check && npm run test",
    "preview": "vite preview",
    "build:webview": "vite build --config vite.webview.config.ts",
    "test:unit": "vitest run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mantine/charts": "^7.17.8",
    "@mantine/core": "^7.17.8",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "openapi-fetch": "^0.13.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remeda": "^2.39.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.11",
    "@stoplight/spectral-cli": "^6.14.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
